[Unit]
Description=Limelight_networkresponder
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/usr/local/bin/visionserver
ExecStart=/usr/local/bin/visionserver/networkresponder
Restart=always
RestartSec=2
StartLimitInterval=0
StartLimitBurst=1000

[Install]
WantedBy=default.target
